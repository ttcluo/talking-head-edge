<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Talking Head Edge Benchmark"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/tvModelPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模型路径: /sdcard/Download/unet_student_int8.onnx"
        android:textSize="12sp"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnCpu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CPU 推理"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnNnapi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NNAPI 推理"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnBenchmark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="完整基准测试（CPU vs NNAPI × 20次）"
        android:paddingBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:padding="8dp"
            android:background="#F5F5F5"
            android:text="点击按钮开始测试..."/>
    </ScrollView>

</LinearLayout>
